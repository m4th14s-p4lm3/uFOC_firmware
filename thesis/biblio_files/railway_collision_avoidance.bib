	year = {2010},
	note = {00045},
	keywords = {Cellular networks, navigation, V2V, VANET, INS, Collision avoidance support, DGPS, Vehicular communications},
	pages = {351--366},
	file = {Santa et al_2010_An analysis of communication and navigation issues in collision avoidance.pdf:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/5D7DV36G/Santa et al_2010_An analysis of communication and navigation issues in collision avoidance.pdf:application/pdf;ScienceDirect Snapshot:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/KTFRUXXH/S0968090X09000655.html:text/html}
