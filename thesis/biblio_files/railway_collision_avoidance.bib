	pages = {140--145},
	file = {IEEE Xplore Abstract Record:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/M989IFV3/6696283.html:text/html;Liu et al_2013_Generating an electronic track map for train collision early warning system.pdf:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/4A5BWZGJ/Liu et al_2013_Generating an electronic track map for train collision early warning system.pdf:application/pdf}
