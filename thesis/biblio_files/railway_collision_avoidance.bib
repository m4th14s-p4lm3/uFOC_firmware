@article{taleb_toward_2010,
	title = {Toward an {Effective} {Risk}-{Conscious} and {Collaborative} {Vehicular} {Collision} {Avoidance} {System}},
	volume = {59},
	issn = {0018-9545},
	doi = {10.1109/TVT.2010.2040639},
	abstract = {In this paper, we introduce a cooperative collision-avoidance (CCA) scheme for intelligent transport systems. Unlike contemporary strategies, the envisioned scheme avoids flooding the considered vehicular network with high volumes of emergency messages upon accidental events. We present a cluster-based organization of the target vehicles. The cluster is based upon several criteria, which define the movement of the vehicles, namely, the directional bearing and relative velocity of each vehicle, as well as the inter-vehicular distance. We also design a risk-aware medium-access control (MAC) protocol to increase the responsiveness of the proposed CCA scheme. According to the order of each vehicle in its corresponding cluster, an emergency level is associated with the vehicle that signifies the risk of encountering a potential emergency scenario. To swiftly circulate the emergency notifications to collocated vehicles to mitigate the risk of chain collisions, the medium-access delay of each vehicle is set as a function of its emergency level. Due to its twofold contributions, i.e., the cluster-based and risk-conscious approaches, our adopted strategy is referred to as the cluster-based risk-aware CCA (C-RACCA) scheme. The performance of the C-RACCA system is verified through mathematical analyses and computer simulations, whose results clearly verify its effectiveness in mitigating collision risks of the vehicles arising from accidental hazards.},
	number = {3},
	journal = {IEEE Transactions on Vehicular Technology},
	author = {Taleb, T. and Benslimane, A. and Letaief, K. B.},
	month = mar,
	year = {2010},
	note = {00111},
	keywords = {intelligent control, automobiles, Ad hoc networks, Access protocols, collision avoidance, mobile radio, MAC, vehicular network, vehicular ad-hoc network (VANET), intelligent transport systems, intervehicle communication (IVC), Cooperative collision avoidance (CCA), cluster based organization, cluster based risk aware collaborative collision avoidance, transport control, risk conscious vehicular collision avoidance system, medium access delay, directional bearing, medium access control protocol, intervehicular distance, envisioned scheme, collaborative vehicular collision avoidance system, vehicle relative velocity, risk analysis},
	pages = {1474--1486},
	file = {IEEE Xplore Abstract Record:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/7U5IT2IJ/5382585.html:text/html;Taleb et al_2010_Toward an Effective Risk-Conscious and Collaborative Vehicular Collision.pdf:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/ZER8GTH4/Taleb et al_2010_Toward an Effective Risk-Conscious and Collaborative Vehicular Collision.pdf:application/pdf}
}

@inproceedings{yin_performance_2004,
	address = {New York, NY, USA},
	series = {{VANET} '04},
	title = {Performance {Evaluation} of {Safety} {Applications} over {DSRC} {Vehicular} {Ad} {Hoc} {Networks}},
	isbn = {978-1-58113-922-8},
	url = {http://doi.acm.org/10.1145/1023875.1023877},
	doi = {10.1145/1023875.1023877},
	abstract = {In this paper we conduct a feasibility study of delay-critical safety applications over vehicular ad hoc networks based on the emerging dedicated short range communications (DSRC) standard. In particular, we quantify the bit error rate, throughput and latency associated with vehicle collision avoidance applications running on top of mobile ad hoc networks employing the physical and MAC layers of DSRC. Towards this objective, the study goes through two phases. First, we conduct a detailed simulation study of the DSRC physical layer in order to judge the link bit error rate performance under a wide variety of vehicles speeds and multi-path delay spreads. We observe that the physical layer is highly immune to large delay spreads that might arise in the highway environment whereas performance degrades considerably at high speeds in a multi-path environment. Second, we develop a simulation testbed for a DSRC vehicular ad hoc network executing vehicle collision avoidance applications in an attempt to gauge the level of support the DSRC standard provides for this type of applications. Initial results reveal that DSRC achieves promising latency performance, yet, the throughput performance needs further improvement.},
	urldate = {2017-05-12},
	booktitle = {Proceedings of the 1st {ACM} {International} {Workshop} on {Vehicular} {Ad} {Hoc} {Networks}},
	publisher = {ACM},
	author = {Yin, Jijun and ElBatt, Tamer and Yeung, Gavin and Ryu, Bo and Habermas, Stephen and Krishnan, Hariharan and Talty, Timothy},
	year = {2004},
	note = {00484},
	keywords = {SIMULATION, Throughput, DSRC, OFDM, MANETs, safety applications, latency, bit error rate, intervehicle communications},
	pages = {1--9},
	file = {Yin et al_2004_Performance Evaluation of Safety Applications over DSRC Vehicular Ad Hoc.pdf:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/NHGW54DG/Yin et al_2004_Performance Evaluation of Safety Applications over DSRC Vehicular Ad Hoc.pdf:application/pdf}
