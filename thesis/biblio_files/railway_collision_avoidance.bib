@inproceedings{tatchikou_cooperative_2005,
	title = {Cooperative vehicle collision avoidance using inter-vehicle packet forwarding},
	volume = {5},
	doi = {10.1109/GLOCOM.2005.1578262},
	abstract = {This paper proposes a broadcast based packet forwarding mechanism for intra-platoon cooperative collision avoidance (CCA) using dedicated short range communication (DSRC) links. The paper first motivates the needs for broadcast forwarding as opposed to unicast routing for transporting inter-vehicle data for safety-critical applications. Then it introduces an implicit acknowledgement mechanism for reducing the amount of broadcast traffic for enhanced packet delivery rate. We have developed a discrete event hybrid simulator InventSim, which is capable of jointly simulating DSRC based vehicular wireless networks, highway vehicle traffic with car following logic and various drivers' reaction models, and ITS application interface to the wireless network. Performance of the proposed broadcast forwarding for a CCA system has been characterized using InventSim. Reported results demonstrate that with inter-vehicle spacing of nearly one second, the proposed mechanism is capable of saving up to 90\% of vehicles in a platoon from chain crashes following emergency events at the front of the platoon. The system has been also evaluated for a wide range of parameters including vehicle spacing, drivers' reaction time, and the amount of background non-CCA traffic},
	booktitle = {{GLOBECOM} '05. {IEEE} {Global} {Telecommunications} {Conference}, 2005.},
	author = {Tatchikou, R. and Biswas, S. and Dion, F.},
	month = dec,
	year = {2005},
	note = {00072},
	keywords = {wireless networks, Road transportation, Routing, collision avoidance, discrete event simulation, radio networks, Vehicle driving, telecommunication network routing, traffic control, Broadcasting, Telecommunication traffic, Unicast, inter-vehicle packet forwarding, cooperative vehicle collision avoidance, acknowledgement mechanism, broadcast traffic, unicast routing, packet delivery rate, dedicated short range communication links, radio links, safety-critical applications, InventSim, discrete event hybrid simulator, vehicular wireless networks},
	pages = {5 pp.--2766},
	file = {IEEE Xplore Abstract Record:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/FGRV7KS4/1578262.html:text/html;Tatchikou et al_2005_Cooperative vehicle collision avoidance using inter-vehicle packet forwarding.pdf:/home/hurak/.mozilla/firefox/md50i6qy.default/zotero/storage/7VCNG6XJ/Tatchikou et al_2005_Cooperative vehicle collision avoidance using inter-vehicle packet forwarding.pdf:application/pdf}
